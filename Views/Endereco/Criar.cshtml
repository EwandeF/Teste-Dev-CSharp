@model TesteDevCSharp.ViewModels.EnderecoViewModel
@{
    ViewData["Title"] = "Novo Endereço";
}

<h5 class="mb-4">Novo Endereço</h5>

@if (ViewBag.Erro != null)
{
    <div class="alert alert-danger">@ViewBag.Erro</div>
}

<form method="post">
    @Html.AntiForgeryToken()

    <div class="row mb-3">
        <div class="col-md-4">
            <label class="form-label">CEP</label>
            <div class="input-group">
                <input type="text" id="cepVisual" name="Cep" class="form-control"
                       value="@Model.Cep" maxlength="9" placeholder="Ex: 01310-100 ou 01310100"
                       oninput="this.value = this.value.replace(/[^\d-]/g, '')" />
                <button type="button" class="btn btn-outline-secondary" onclick="buscarCep()">Buscar CEP</button>
            </div>
            @Html.ValidationMessageFor(m => m.Cep, "", new { @class = "text-danger" })
        </div>
    </div>

    <div class="row mb-3">
        <div class="col-md-6">
            <label class="form-label">Logradouro</label>
            <input type="text" id="logradouro" name="Logradouro" class="form-control"
                   value="@Model.Logradouro" />
            @Html.ValidationMessageFor(m => m.Logradouro, "", new { @class = "text-danger" })
        </div>
        <div class="col-md-2">
            <label class="form-label">Número</label>
            <input type="text" name="Numero" class="form-control"
                   value="@Model.Numero"
                   oninput="this.value = this.value.replace(/\D/g, '')" />
            @Html.ValidationMessageFor(m => m.Numero, "", new { @class = "text-danger" })
        </div>
        <div class="col-md-4">
            <label class="form-label">Complemento</label>
            <input type="text" name="Complemento" class="form-control"
                   value="@Model.Complemento" />
        </div>
    </div>

    <div class="row mb-3">
        <div class="col-md-4">
            <label class="form-label">Bairro</label>
            <input type="text" id="bairro" name="Bairro" class="form-control"
                   value="@Model.Bairro" />
            @Html.ValidationMessageFor(m => m.Bairro, "", new { @class = "text-danger" })
        </div>
        <div class="col-md-4">
            <label class="form-label">Cidade</label>
            <input type="text" id="cidade" name="Cidade" class="form-control"
                   value="@Model.Cidade" />
            @Html.ValidationMessageFor(m => m.Cidade, "", new { @class = "text-danger" })
        </div>
        <div class="col-md-2">
            <label class="form-label">UF</label>
            <input type="text" id="uf" name="Uf" class="form-control"
                   value="@Model.Uf" maxlength="2" />
            @Html.ValidationMessageFor(m => m.Uf, "", new { @class = "text-danger" })
        </div>
    </div>

    <div class="mt-3">
        <button type="submit" class="btn btn-primary">Salvar</button>
        <a href="/Endereco/Index" class="btn btn-secondary ms-2">Cancelar</a>
    </div>
</form>

@section Scripts {
    <script>

        const txtCep = document.getElementById("cepVisual");
        const txtLogradouro = document.getElementById("logradouro");
        const txtBairro = document.getElementById("bairro");
        const txtCidade = document.getElementById("cidade");
        const txtUf = document.getElementById("uf");
        const txtNumero = document.querySelector('input[name="Numero"]');

        const btnBuscar = document.querySelector(".input-group button");

        async function buscarCep() {

            const cep = txtCep.value.replace(/\D/g, '');

            if (cep.length !== 8) {
                alert("Informe um CEP válido com 8 dígitos.");
                txtCep.focus();
                return;
            }

            btnBuscar.disabled = true;
            btnBuscar.innerHTML = "Buscando...";

            try {

                const resposta = await fetch(`/Endereco/BuscarCep?cep=${cep}`);

                if (!resposta.ok) {
                    throw new Error();
                }

                const data = await resposta.json();

                if (data.erro) {
                    alert("CEP não encontrado.");
                    txtCep.focus();
                    txtCep.select();
                    return;
                }

                txtLogradouro.value = data.logradouro ?? "";
                txtBairro.value = data.bairro ?? "";
                txtCidade.value = data.localidade ?? "";
                txtUf.value = data.uf ?? "";

                // Vai automaticamente para o Número
                txtNumero.focus();

            }
            catch {

                alert("Erro ao consultar o ViaCEP.");

                txtCep.focus();

            }
            finally {

                btnBuscar.disabled = false;
                btnBuscar.innerHTML = "Buscar CEP";

            }

        }

        // Clique no botão
        btnBuscar.addEventListener("click", buscarCep);

        // Enter no CEP
        txtCep.addEventListener("keydown", function (e) {

            if (e.key === "Enter") {

                e.preventDefault();

                buscarCep();

            }

        });

        // Busca automaticamente ao sair do campo CEP
        txtCep.addEventListener("blur", function () {

            const cep = txtCep.value.replace(/\D/g, '');

            if (cep.length === 8 &&
                txtLogradouro.value.trim() === "") {

                buscarCep();

            }

        });

    </script>
}