@model List<TesteDevCSharp.Models.Endereco>
@{
    ViewData["Title"] = "Meus Endereços";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4>Olá, @ViewBag.UsuarioNome!</h4>
    <div>
        <a href="/Endereco/ExportarCsv" class="btn btn-success btn-sm">Exportar CSV</a>
        <a href="/Account/Logout" class="btn btn-outline-secondary btn-sm">Sair</a>
    </div>
</div>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5>Meus Endereços</h5>
    <a href="/Endereco/Criar" class="btn btn-primary btn-sm">+ Novo Endereço</a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">Nenhum endereço cadastrado ainda.</div>
}
else
{
    <table class="table table-bordered table-hover">
        <thead class="table-dark">
            <tr>
                <th>CEP</th>
                <th>Logradouro</th>
                <th>Número</th>
                <th>Bairro</th>
                <th>Cidade</th>
                <th>UF</th>
                <th>Ações</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var e in Model)
            {
                <tr>
                    <td>@e.Cep</td>
                    <td>@e.Logradouro</td>
                    <td>@e.Numero</td>
                    <td>@e.Bairro</td>
                    <td>@e.Cidade</td>
                    <td>@e.Uf</td>
                    <td>
                        <a href="/Endereco/Editar/@e.Id" class="btn btn-warning btn-sm">Editar</a>
                        <form method="post" action="/Endereco/Excluir/@e.Id" style="display:inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-danger btn-sm"
                                    onclick="return confirm('Confirma exclusão?')">
                                Excluir
                            </button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}